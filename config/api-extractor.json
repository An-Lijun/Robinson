{
    "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",
    "mainEntryPointFilePath": "../dist/esm/types/index.d.ts",
    "bundledPackages": [],
    "compiler": {
        "tsconfigFilePath": "../tsconfig.json"
    },
    "apiReport": {
        "enabled": true,
        "reportTempFolder": "../vitepress/temp/"
    },
    "docModel": {
        "enabled": true,
        "apiJsonFilePath": "../vitepress/temp/robinson.api.json"
    },
    "dtsRollup": {
        "enabled": true
    },
    "tsdocMetadata": {},
    "messages": {
        "compilerMessageReporting": {
            "default": {
                "logLevel": "warning"
            }
        },
        "extractorMessageReporting": {
            "default": {
                "logLevel": "warning"
            },
            "ae-missing-release-tag": {
                "logLevel": "none"
            }
        },
        "tsdocMessageReporting": {
            "default": {
                "logLevel": "warning"
            },
            "tsdoc-escape-greater-than": {
                "logLevel": "none"
            },
            "tsdoc-malformed-inline-tag": {
                "logLevel": "none"
            },
            "tsdoc-escape-right-brace": {
                "logLevel": "none"
            },
            "tsdoc-param-tag-with-invalid-optional-name": {
                "logLevel": "none"
            },
            "tsdoc-param-tag-missing-hyphen": {
                "logLevel": "none"
            }
        }
    }
}